{
  "suite": "diamond_runtime_v0_core",
  "cases": [
    {"id": "idiv.basic", "fn": "idiv", "args": [7, 2], "expect": 3},
    {"id": "idiv.neg_floor", "fn": "idiv", "args": [-3, 2], "expect": -2},
    {"id": "idiv.zero_div", "fn": "idiv", "args": [1, 0], "expect_error": {"type": "ZeroDivisionError", "contains": "divide by zero"}},

    {"id": "midpoint.even", "fn": "midpoint", "args": [2, 6], "expect": 4},
    {"id": "midpoint.odd", "fn": "midpoint", "args": [1, 6], "expect": 3},

    {"id": "left_half.even", "fn": "left_half", "args": [[1, 2, 3, 4]], "expect": [1, 2]},
    {"id": "left_half.odd", "fn": "left_half", "args": [[1, 2, 3, 4, 5]], "expect": [1, 2]},
    {"id": "right_half.even", "fn": "right_half", "args": [[1, 2, 3, 4]], "expect": [3, 4]},
    {"id": "right_half.odd", "fn": "right_half", "args": [[1, 2, 3, 4, 5]], "expect": [3, 4, 5]},

    {"id": "patch.update", "fn": "patch", "args": [{"a": 1, "b": 2}, {"b": 9}], "expect": {"a": 1, "b": 9}, "assert_args_unchanged": [0]},
    {"id": "patch.add", "fn": "patch", "args": [{"a": 1}, {"b": 2}], "expect": {"a": 1, "b": 2}, "assert_args_unchanged": [0]},

    {"id": "member.dict", "fn": "member", "args": [{"x": 7}, "x"], "expect": 7},
    {"id": "member.object", "fn": "member", "args": [{"$obj": {"attrs": {"x": 3, "y": 4}}}, "y"], "expect": 4},
    {"id": "member.missing", "fn": "member", "args": [{"x": 7}, "z"], "expect_error": {"type": "KeyError", "contains": "z"}},
    {"id": "index.array.ok", "fn": "index", "args": [[1, 2, 3], 1], "expect": 2},
    {"id": "index.array.oob", "fn": "index", "args": [[1, 2, 3], 9], "expect_error": {"type": "IndexError", "contains": "out of range"}},
    {"id": "index.string.ok", "fn": "index", "args": ["abc", 1], "expect": "b"},
    {"id": "index.string.oob", "fn": "index", "args": ["abc", 9], "expect_error": {"type": "IndexError", "contains": "out of range"}},

    {"id": "range_inclusive.asc", "fn": "range_inclusive", "args": [2, 5], "expect": [2, 3, 4, 5]},
    {"id": "range_inclusive.desc", "fn": "range_inclusive", "args": [5, 2], "expect": []},

    {"id": "fold.sum", "fn": "fold", "args": [[1, 2, 3], 0, {"$fn": "sum2"}], "expect": 6},
    {"id": "fold.empty", "fn": "fold", "args": [[], 10, {"$fn": "sum2"}], "expect": 10},
    {"id": "fold.concat", "fn": "fold", "args": [["a", "b", "c"], "", {"$fn": "concat2"}], "expect": "a,b,c"},

    {"id": "ln.list", "fn": "ln", "args": [[1, 2, 3]], "expect": 3},
    {"id": "ln.unicode", "fn": "ln", "args": ["café"], "expect": 4},
    {"id": "trim.basic", "fn": "trim", "args": ["  hi \n"], "expect": "hi"},
    {"id": "split.basic", "fn": "split", "args": ["a,b,c", ","], "expect": ["a", "b", "c"]},
    {"id": "split.unicode_sep", "fn": "split", "args": ["a💎b💎c", "💎"], "expect": ["a", "b", "c"]},
    {"id": "split.no_delim", "fn": "split", "args": ["abc", ","], "expect": ["abc"]},
    {"id": "split.empty_sep", "fn": "split", "args": ["abc", ""], "expect_error": {"type": "ValueError", "contains": "empty separator"}},
    {"id": "peek.in_bounds", "fn": "peek", "args": ["abc", 1, null], "expect": "b"},
    {"id": "peek.oob_default", "fn": "peek", "args": ["abc", 10, "_"], "expect": "_"},
    {"id": "take.basic", "fn": "take", "args": ["abcdef", 1, 3], "expect": "bcd"},
    {"id": "take.oob", "fn": "take", "args": ["abc", 9, 2], "expect": ""},
    {"id": "guard.true", "fn": "guard", "args": [true, "ok", 1], "expect": true},
    {"id": "guard.false", "fn": "guard", "args": [false, "bad", 7], "expect_error": {"type": "RuntimeError", "contains": "bad"}},

    {"id": "put.add", "fn": "put", "args": [{"a": 1}, "b", 2], "expect": {"a": 1, "b": 2}, "assert_args_unchanged": [0]},
    {"id": "get.hit", "fn": "get", "args": [{"a": 1}, "a", 0], "expect": 1},
    {"id": "get.miss", "fn": "get", "args": [{"a": 1}, "b", 0], "expect": 0},
    {"id": "del.existing", "fn": "del_", "args": [{"a": 1, "b": 2}, "a"], "expect": {"b": 2}, "assert_args_unchanged": [0]},
    {"id": "del.missing", "fn": "del_", "args": [{"a": 1}, "z"], "expect": {"a": 1}, "assert_args_unchanged": [0]},

    {"id": "to_s.num", "fn": "to_s", "args": [12], "expect": "12"},
    {"id": "to_i.str", "fn": "to_i", "args": ["42"], "expect": 42},
    {"id": "to_i.invalid", "fn": "to_i", "args": ["0x10"], "expect_error": {"type": "ValueError", "contains": "invalid literal"}},
    {"id": "to_b.zero", "fn": "to_b", "args": [0], "expect": false},
    {"id": "to_b.nonempty", "fn": "to_b", "args": ["x"], "expect": true},
    {"id": "to_o.identity", "fn": "to_o", "args": [[1, 2]], "expect": [1, 2]},
    {"id": "json_dumps.basic", "fn": "json_dumps", "args": [{"a": 1, "b": [2, 3]}], "expect": "{\"a\":1,\"b\":[2,3]}"},
    {"id": "json_loads.basic", "fn": "json_loads", "args": ["{\"a\":1,\"b\":[2,3]}"], "expect": {"a": 1, "b": [2, 3]}},
    {"id": "json_roundtrip.unicode", "fn": "json_loads", "args": ["{\"msg\":\"💎\"}"], "expect": {"msg": "💎"}},
    {"id": "json_loads.invalid", "fn": "json_loads", "args": ["{bad"], "expect_error": {"type": "JSONDecodeError", "contains": "Expecting property name"}},
    {"id": "obj.json.dumps", "fn": "call_with", "args": [{"$fn": "obj_json_dumps"}, null, null], "expect": "{\"x\":1,\"tags\":[2,3]}"},
    {"id": "dt.date.iso", "fn": "call_with", "args": [{"$fn": "dt_date_iso"}, null, null], "expect": "2024-02-09"},
    {"id": "dt.datetime.iso", "fn": "call_with", "args": [{"$fn": "dt_datetime_iso"}, null, null], "expect": "2024-02-09T10:11:12.013000+00:00"},
    {"id": "dt.time.iso", "fn": "call_with", "args": [{"$fn": "dt_time_iso"}, null, null], "expect": "10:11:12.013000"},
    {"id": "tz.utc.str", "fn": "call_with", "args": [{"$fn": "tz_utc_str"}, null, null], "expect": "UTC"},
    {"id": "tz.offset.str", "fn": "call_with", "args": [{"$fn": "tz_offset_str"}, null, null], "expect": "UTC+02:30"},
    {"id": "pad6.basic", "fn": "call_with", "args": [{"$fn": "pad6_basic"}, null, null], "expect": "420000"},
    {"id": "ibase.hex", "fn": "call_with", "args": [{"$fn": "parse_int_base_hex"}, null, null], "expect": 255},

    {"id": "call_with.basic", "fn": "call_with", "args": [{"$fn": "add_ab_c"}, [2, 3], {"c": 4}], "expect": 9},
    {"id": "call_with.none", "fn": "call_with", "args": [{"$fn": "const_5"}, null, null], "expect": 5},
    {"id": "extern_call.stub", "fn": "extern_call", "args": ["dep.fn", [1, 2]], "expect_error": {"type": "NotImplementedError", "contains": "external contract stub invoked"}},
    {"id": "is_tuple.true", "fn": "is_tuple", "args": [{"$tuple": [1, 2]}], "expect": true},
    {"id": "is_tuple.false", "fn": "is_tuple", "args": [[1, 2]], "expect": false},

    {"id": "try_catch.handle", "fn": "try_catch", "args": [{"$fn": "raise_value_error"}, {"$fn": "handler_msg"}], "expect": "handled:boom"},
    {"id": "try_catch.reraise", "fn": "try_catch", "args": [{"$fn": "raise_value_error"}, {"$fn": "handler_reraise"}], "expect_error": {"type": "ValueError", "contains": "boom"}},
    {"id": "try_catch.over.propagate", "fn": "try_catch", "args": [{"$fn": "propagate_raised"}, {"$fn": "handler_type"}], "expect": "caught:ValueError"},
    {"id": "propagate.value", "fn": "propagate", "args": [7], "expect": 7},
    {"id": "propagate.callable", "fn": "propagate", "args": [{"$fn": "const_5"}], "expect": 5},
    {"id": "propagate.over.try_handle", "fn": "propagate", "args": [{"$fn": "try_handle_via_runtime"}], "expect": "handled:boom"},
    {"id": "propagate.over.try_reraise", "fn": "propagate", "args": [{"$fn": "try_reraise_via_runtime"}], "expect_error": {"type": "ValueError", "contains": "boom"}},
    {"id": "propagate.error", "fn": "propagate", "args": [{"$fn": "raise_value_error"}], "expect_error": {"type": "ValueError", "contains": "boom"}},
    {"id": "cap.allow_all", "fn": "call_with", "args": [{"$fn": "cap_allow_all_ok"}, null, null], "expect": "ok"},
    {"id": "cap.allow_list.pass", "fn": "call_with", "args": [{"$fn": "cap_allow_list_ok"}, null, null], "expect": "ok"},
    {"id": "cap.allow_list.fail", "fn": "call_with", "args": [{"$fn": "cap_allow_list_fail"}, null, null], "expect_error": {"type": "PermissionError", "contains": "missing capabilities"}},

    {"id": "obj.alias.identity_true", "fn": "call_with", "args": [{"$fn": "obj_alias_identity_true"}, null, null], "expect": true},
    {"id": "obj.alias.mutation_visible", "fn": "call_with", "args": [{"$fn": "obj_alias_mutation_visible"}, null, null], "expect": 9},
    {"id": "obj.closed_shape.reject_set_missing", "fn": "call_with", "args": [{"$fn": "obj_closed_shape_set_missing"}, null, null], "expect_error": {"type": "AttributeError", "contains": "unknown field"}},
    {"id": "obj.closed_shape.reject_get_missing", "fn": "call_with", "args": [{"$fn": "obj_get_missing_field"}, null, null], "expect_error": {"type": "AttributeError", "contains": "unknown field"}},
    {"id": "obj.eq.structural_true", "fn": "call_with", "args": [{"$fn": "obj_eq_structural_true"}, null, null], "expect": true},
    {"id": "obj.eq.structural_false", "fn": "call_with", "args": [{"$fn": "obj_eq_structural_false"}, null, null], "expect": false},
    {"id": "obj.eq.cycle_true", "fn": "call_with", "args": [{"$fn": "obj_eq_cycle_true"}, null, null], "expect": true},
    {"id": "obj.eq.cycle_false", "fn": "call_with", "args": [{"$fn": "obj_eq_cycle_false"}, null, null], "expect": false},
    {"id": "obj.invoke.method_ok", "fn": "call_with", "args": [{"$fn": "obj_invoke_method_ok"}, null, null], "expect": 3},
    {"id": "obj.invoke.missing_method", "fn": "call_with", "args": [{"$fn": "obj_invoke_missing_method"}, null, null], "expect_error": {"type": "AttributeError", "contains": "unknown method"}},
    {"id": "obj.invoke.fallback_member", "fn": "call_with", "args": [{"$fn": "obj_invoke_fallback_member"}, null, null], "expect": 5},

    {"id": "ini_iscommentline.true", "fn": "ini_iscommentline", "args": ["  # x"], "expect": true},
    {"id": "ini_iscommentline.false", "fn": "ini_iscommentline", "args": ["x #"], "expect": false},
    {"id": "ini_parseline.section", "fn": "ini_parseline", "args": ["p", "[sec] # c", 0, false, false], "expect": ["sec", null]},
    {"id": "ini_parseline.value_strip", "fn": "ini_parseline", "args": ["p", "name = 1 # x", 0, true, false], "expect": ["name", "1"]},
    {"id": "ini_parseline.bad", "fn": "ini_parseline", "args": ["p", "!!", 2, false, false], "expect_error": {"type": "IniParseError", "contains": "unexpected line"}},
    {"id": "ini_parse_lines.continuation", "fn": "ini_parse_lines", "args": ["p", ["[s]\n", "name=1\n", " more\n"], false, false], "expect": [[0, "s", null, null], [1, "s", "name", "1\nmore"]]},
    {"id": "ini_parse_lines.unexpected_cont", "fn": "ini_parse_lines", "args": ["p", [" more\n"], false, false], "expect_error": {"type": "IniParseError", "contains": "unexpected value continuation"}},
    {"id": "ini_parse_ini_data.ok", "fn": "ini_parse_ini_data", "args": ["p", "[s]\nname=1\n", false, false], "expect": [{"s": {"name": "1"}}, [[["s", "name"], 1], [["s", null], 0]]]},
    {"id": "ini_parse_ini_data.dup_section", "fn": "ini_parse_ini_data", "args": ["p", "[s]\n[s]\n", false, false], "expect_error": {"type": "IniParseError", "contains": "duplicate section"}},
    {"id": "ini_parse_ini_data.no_section", "fn": "ini_parse_ini_data", "args": ["p", "a=1\n", false, false], "expect_error": {"type": "IniParseError", "contains": "no section header defined"}},

    {"id": "ini_pair.basic", "fn": "ini_pair", "args": ["s", "k"], "expect": ["s", "k"]},
    {"id": "ini_repr.str", "fn": "ini_repr", "args": ["x"], "expect": "'x'"},
    {"id": "ini_splitlines_keepends", "fn": "ini_splitlines_keepends", "args": ["a\nb\n"], "expect": ["a\n", "b\n"]},
    {"id": "ini_raise.error", "fn": "ini_raise", "args": ["p", 1, "x"], "expect_error": {"type": "IniParseError", "contains": "x"}}
  ]
}
